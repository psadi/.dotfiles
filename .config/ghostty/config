# vim: set ft=config

font-family = "GeistMono NF Medium"
font-size = 16
theme = "tokyonight_night"
maximize = true
gtk-tabs-location = "hidden"
quick-terminal-position = "top"
quick-terminal-screen = "mouse"

# Keybinds

# Tabs
keybind = "ctrl+t=new_tab"
keybind = "ctrl+shift+t=toggle_tab_overview"
keybind = "ctrl+[=previous_tab"
keybind = "ctrl+shift+[=move_tab:-1"
keybind = "ctrl+]=next_tab"
keybind = "ctrl+shift+]=move_tab:1"

# Splits
keybind = "ctrl+shift+j=new_split:down"
keybind = "ctrl+shift+h=new_split:left"
keybind = "ctrl+shift+k=new_split:up"
keybind = "ctrl+shift+l=new_split:right"
keybind = "ctrl+alt+j=resize_split:down,10"
keybind = "ctrl+alt+h=resize_split:left,10"
keybind = "ctrl+alt+k=resize_split:up,10"
keybind = "ctrl+alt+l=resize_split:right,10"
keybind = "ctrl+shift+enter=equalize_splits"

# Quick Term
keybind = "ctrl+shift+q=toggle_quick_terminal"
